// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  trailerUrl  String?
  bannerUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Music {
  id        String   @id @default(cuid())
  title     String
  audioUrl  String
  posterUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CastCrew {
  id        String   @id @default(cuid())
  name      String
  role      String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Poster {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
